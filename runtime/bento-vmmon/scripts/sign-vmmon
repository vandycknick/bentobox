#!/usr/bin/env bash
set -euo pipefail

if [[ "$(uname -s)" != "Darwin" ]]; then
  exit 0
fi

if [[ $# -ne 1 ]]; then
  printf 'usage: %s <vmmon-binary>\n' "$0" >&2
  exit 2
fi

bin="$1"
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
entitlements="$script_dir/../vmmon.entitlements"

if [[ ! -f "$bin" ]]; then
  printf 'vmmon binary not found: %s\n' "$bin" >&2
  exit 1
fi

/usr/bin/codesign -f --entitlements "$entitlements" -s - "$bin"
/usr/bin/codesign --verify --verbose=4 "$bin"
